# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=50051
MAX_WORKERS=10

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/resources
DATABASE_POOL_SIZE=10

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring and Observability
ENABLE_METRICS=true
METRICS_PORT=8080
ENABLE_TRACING=true
JAEGER_ENDPOINT=http://localhost:14268

# Security
ENABLE_TLS=false
CERT_FILE=/path/to/cert.pem
KEY_FILE=/path/to/key.pem

# Environment
ENVIRONMENT=development
DEBUG=false